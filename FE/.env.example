# Copy to `.env` next to `server.js` when running the Express API (`node server.js`).

# Path template for lecturer quiz deep links returned by POST /api/quiz/generate (`navigateTo`).
# Must match the React route in App.tsx (e.g. /quiz/:id?tab=edit&selectedId=:id).
# Placeholders :id or :quizId are replaced with the numeric quiz id (all occurrences).
QUIZ_LECTURER_NAVIGATE_PATH_TEMPLATE=/quiz/:id?tab=edit&selectedId=:id
