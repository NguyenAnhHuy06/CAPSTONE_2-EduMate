# --- Kết nối FE (Vite) ↔ Backend (Express) ---
# Sao chép file này thành `.env` và chỉnh nếu cần:  copy .env.example .env

# Cách A (khuyến nghị khi dev): ĐỂ TRỐNG → axios gọi `/api` cùng origin Vite, Vite proxy chuyển sang backend.
# VITE_API_URL=

# Cách B: Gọi thẳng backend (bỏ qua proxy; backend BE phải chạy và CORS đã bật).
# VITE_API_URL=http://localhost:3001

# Địa chỉ backend cho proxy `/api` (chỉ khi dùng Cách A — VITE_API_URL trống).
VITE_PROXY_TARGET=http://localhost:3001

# Port chạy Vite (mặc định 5173). Đổi nếu port bận.
# VITE_DEV_PORT=5173
