PORT=3000



# OpenRouter (chat/quiz generation)
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=deepseek/deepseek-chat
# CHAT_MAX_RETRIES=5
# Trần output JSON quiz (mặc định logic code ~2800, tối đa 8192). Nếu vẫn lỗi parse — tăng giá trị này.
# QUIZ_MAX_TOKENS=3500
# Một số model OpenRouter lỗi với json_object: đặt 0 để tắt response_format.
# QUIZ_OPENROUTER_JSON_MODE=1

# Gemini (embedding)
GEMINI_API_KEY=
# GEMINI_EMBEDDING_MODEL=models/text-embedding-004
# GEMINI_EMBED_BASE=https://generativelanguage.googleapis.com/v1beta

# Kích thước chunk khi index S3 → MySQL

# Chunk theo word (300-500), giữ câu + overlap nhỏ
# EMBED_MAX_CHUNKS=80

# Giới hạn song song khi gọi Gemini embed (tránh 429): mặc định 4, tối đa 5
# EMBED_CONCURRENCY=4




# AWS S3 (bắt buộc cho upload + danh sách quiz; không lưu file local)

AWS_REGION=ap-southeast-1

AWS_ACCESS_KEY_ID=

AWS_SECRET_ACCESS_KEY=
S3_BUCKET=

# Tiền tố list file (mặc định documents/)

# S3_DOCUMENTS_PREFIX=documents/

# URL công khai nếu bucket dùng CDN / custom domain

# S3_PUBLIC_BASE_URL=



# MySQL (bắt buộc cho embedding + quiz từ s3Key: chunk + vector lưu DB)

# Cách 1: URL

# DATABASE_URL=mysql://user:password@localhost:3306/edumate

# Cách 2: MYSQL_*

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# Cách 3: DB_* (tương đương, backend đọc cả hai)

# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=
# DB_PASSWORD=
# DB_NAME=edumate

# Backend dùng bảng documents + document_segments + quizzes + quiz_questions (schema edumate của bạn).
# documents.file_url lưu S3 object key (không phải URL đầy đủ), khớp với key từ S3.
# Nếu quiz_attempts.user_id là NOT NULL mà FE chưa gửi userId, đặt user mặc định:
# DEFAULT_QUIZ_USER_ID=1
# quiz_attempts.completed_at nên cho phép NULL (lượt Take Quiz đang mở). Ví dụ:
# ALTER TABLE quiz_attempts MODIFY completed_at DATETIME NULL;
# Backend thêm quizzes.source_file_url (S3 key) khi khởi động — dùng đếm Attempts trên /documents/for-quiz.

# --- Quiz publish (giảng viên) ---
# users.role phải khớp một trong các giá trị (không phân biệt hoa thường), mặc định: lecturer, teacher
# LECTURER_ROLES=lecturer,teacher
# Flow: POST /api/quiz/generate với persist + createdBy = user_id giảng viên → PATCH /api/quizzes/:id (chỉnh sửa) → POST /api/quizzes/:id/publish
# Sinh viên chỉ thấy quiz qua GET /api/quizzes/published và GET /api/quizzes/:id khi is_published=1 (hoặc draft nếu viewer là chủ sở hữu + lecturer).

