PORT=3001
JWT_SECRET=

# API rate limit: max requests per IP per 15 minutes (express-rate-limit). Default 100 in production, 2000 in non-production. Set explicitly for fine control.
# RATE_LIMIT_MAX=500

# OTP / SMTP
OTP_EXPIRES_MINUTES=5
OTP_PYTHON_BIN=python
# OTP_PYTHON_SCRIPT=./otp_email_service.py
# OTP_BRAND_NAME=EduMate
# OTP_EMAIL_SUBJECT=Your EduMate verification code
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=false
SMTP_USE_TLS=true
SMTP_TLS_REJECT_UNAUTHORIZED=true



# OpenRouter (chat / quiz generation)
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=deepseek/deepseek-chat
# CHAT_MAX_RETRIES=5
# Max tokens for quiz JSON output (code default ~2800, max 8192). If parsing still fails, raise this.
# QUIZ_MAX_TOKENS=3500
# Some OpenRouter models break with json_object: set 0 to disable response_format.
# QUIZ_OPENROUTER_JSON_MODE=1
# OCR fallback for scanned/slide PDFs (requires local tools: pdftoppm + tesseract)
# PDF_OCR_MAX_PAGES=5
# PDF_OCR_LANG=vie+eng

# After create/generate quiz, API returns navigateTo for the SPA. Use :id as placeholder.
# Default is /quiz/:id. For lecturer apps that use a dedicated route (one-step open, no list tab), set:
# QUIZ_LECTURER_NAVIGATE_PATH_TEMPLATE=/lecturer/quiz/:id
# QUIZ_NAVIGATE_PATH_TEMPLATE=/quiz/:id

# Gemini (embedding)
GEMINI_API_KEY=
# GEMINI_EMBEDDING_MODEL=models/text-embedding-004
# GEMINI_EMBED_BASE=https://generativelanguage.googleapis.com/v1beta

# Chunk size when indexing S3 → MySQL

# Word-based chunks (300–500 words), sentence boundaries + small overlap
# EMBED_MAX_CHUNKS=80

# Parallel Gemini embed calls (avoid 429): default 4, max 5
# EMBED_CONCURRENCY=4




# AWS S3 (required for upload + quiz listing; files are not stored locally)

AWS_REGION=ap-southeast-1

AWS_ACCESS_KEY_ID=

AWS_SECRET_ACCESS_KEY=
S3_BUCKET=

# Prefix for listing objects (default documents/)

# S3_DOCUMENTS_PREFIX=documents/

# Prefix for published lecturer quizzes consumed by students
# S3_PUBLISHED_QUIZ_PREFIX=lecture-quiz/

# Public base URL if the bucket is behind a CDN / custom domain

# S3_PUBLIC_BASE_URL=



# MySQL (required for embeddings + s3Key-based quiz: chunks + vectors in DB)

# Option 1: URL

# DATABASE_URL=mysql://user:password@localhost:3306/edumate

# Option 2: MYSQL_*

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# Option 3: DB_* (equivalent; backend reads both)

# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=
# DB_PASSWORD=
# DB_NAME=edumate

# Backend expects tables documents + document_segments + quizzes + quiz_questions (your edumate schema).
# documents.file_url stores the S3 object key (not a full URL), matching keys from S3.
# If quiz_attempts.user_id is NOT NULL but the FE omits userId, set a default user:
# DEFAULT_QUIZ_USER_ID=1
# quiz_attempts.completed_at should allow NULL (open Take Quiz attempts). Example:
# ALTER TABLE quiz_attempts MODIFY completed_at DATETIME NULL;
# Backend adds quizzes.source_file_url (S3 key) on startup — used for attempt counts on /documents/for-quiz.

# --- Quiz publish (lecturers) ---
# users.role must match one of these (case-insensitive), default: lecturer, teacher
# LECTURER_ROLES=lecturer,teacher
# Flow: POST /api/quiz/generate with persist + createdBy = lecturer user_id → PATCH /api/quizzes/:id (edit) → POST /api/quizzes/:id/publish
# Students only see quizzes via GET /api/quizzes/published and GET /api/quizzes/:id when is_published=1 (or draft if viewer is owner + lecturer).

